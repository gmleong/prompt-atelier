{
  "name": "prompt-library-desktop",
  "version": "0.1.0",
  "description": "Desktop MVP for managing prompt snippets",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "deploy": "node deploy.js",
    "build": "electron-builder --mac"
  },
  "build": {
    "appId": "com.prompt.atelier",
    "productName": "提示词助手",
    "files": ["main.js", "preload.js", "renderer/**/*", "assets/**/*"],
    "mac": {
      "icon": "assets/icon.icns",
      "target": "dmg"
    }
  },
  "devDependencies": {
    "electron": "^31.0.2",
    "electron-builder": "^26.15.3"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "cos-nodejs-sdk-v5": "^3.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "vite": "^8.1.3"
  }
}
